 '<div style="font-size:'+fs(7.5)+'px;color:'+noir+';line-height:1.2;">'+
 '<strong>'+rNom+'</strong><br>'+rAdr+'<br>Tel: '+rTel+
 '</div>'+
 (lot?'<div style="font-size:'+fs(7)+'px;color:'+gris+';margin-top:1px;">N° lot : '+lot+'</div>':'')+
 '</div>'+
 '<div style="width:'+Math.round(24*scale)+'px;height:'+Math.round(24*scale)+'px;flex-shrink:0;" title="CLP Numérique Obligatoire via QR">'+
 generateMiniQRCode(nom)+
 '</div>'+
 '</div>'+
 '</div>';
 return html;
 }

