 function loadClp(id){
 var c=clps.filter(function(x){return x.id===id;})[0];if(!c)return;
 document.getElementById('c-recette').value=c.recette_id||''; document.getElementById('c-fds').value=c.fds_id||'';
 document.getElementById('c-nom').value=c.nom||''; document.getElementById('c-qte').value=c.qte||'';
 document.getElementById('c-lot').value=c.lot||''; document.getElementById('c-allergenes').value=c.allergenes||'';
 document.getElementById('c-avert').value=c.avert||'ATTENTION'; document.getElementById('c-ufi').value=c.ufi||'';
 document.getElementById('c-ufi-req').value=c.ufi_req||'oui'; document.getElementById('c-h-custom').value=c.h_custom||'';
 document.getElementById('c-p-custom').value=c.p_custom||''; document.getElementById('c-format').value=c.format||'rect';
 document.getElementById('c-larg').value=c.larg||80; document.getElementById('c-haut').value=c.haut||52;
 document.getElementById('c-diam').value=c.diam||70; document.getElementById('c-imp').value=c.imp||'couleur';
 document.getElementById('ing-list').innerHTML=''; ingCount=0;
 (c.ings||[]).forEach(function(i){addIng(i.nom,i.pct);}); if(!c.ings||!c.ings.length)addIng();
 resetHPSelection();
 (c.ghs||[]).forEach(function(id){toggleGHS(id);}); (c.h||[]).forEach(function(code){toggleH(code);}); (c.p||[]).forEach(function(code){toggleP(code);});
 updFmt();updAll();
 document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('on');}); document.querySelectorAll('.page').forEach(function(p){p.classList.remove('on');});
 document.querySelectorAll('.tab')[0].classList.add('on'); document.getElementById('page-creer').classList.add('on');
 toast('Étiquette chargée ✓','s');
 }

 function delClp(id){ clps=clps.filter(function(c){return c.id!==id;}); saveClps();updStats();rendBiblio();toast('Supprimé','e'); }
 function rendFds(){
 var el=document.getElementById('list-fds'); if(!fdsList.length){el.innerHTML='<p class="empty">Aucune FDS enregistrée</p>';return;}
 el.innerHTML=fdsList.map(function(f){ return '<div class="fds-card"><strong>'+f.nom+'</strong> ('+f.four+')<button class="btn bd bsm" style="float:right;" onclick="delFds(\''+f.id+'\')">✕</button></div>'; }).join('');
 }
 function saveFds(){
 var nom=document.getElementById('fds-nom').value.trim(); if(!nom){toast('Nom de FDS requis','e');return;}
 var f={id:Date.now().toString(), nom:nom, cat:document.getElementById('fds-cat').value, four:document.getElementById('fds-four').value, notes:document.getElementById('fds-notes').value, extracted:aiExtracted||{}};
 fdsList.push(f); saveFdsList(); updStats(); rendFds(); fillFdsSel(); toast('FDS enregistrée ✓','s');
 }
 function delFds(id){ fdsList=fdsList.filter(function(x){return x.id!==id;}); saveFdsList(); updStats(); rendFds(); fillFdsSel(); }

 function onDrop(e){ e.preventDefault(); document.getElementById('upload-zone').classList.remove('drag'); var f=e.dataTransfer.files[0]; if(f)processFile(f); }
 function onFileSelect(e){ var f=e.target.files[0]; if(f)processFile(f); }
 function processFile(f){
 var ext=f.name.split('.').pop().toLowerCase(); if(!['pdf','doc','docx'].includes(ext)){toast('Format non supporté','e');return;}
 currentFile=f; currentFileType=ext==='pdf'?'pdf':'docx'; document.getElementById('fds-file-name').textContent='📎 '+f.name; document.getElementById('fds-file-name').style.display='block';
 var reader=new FileReader(); reader.onload=function(ev){ currentFileB64=ev.target.result.split(',')[1]; document.getElementById('btn-ai').disabled=false; toast('Fichier prêt pour l\'analyse ✓','s'); };
 reader.readAsDataURL(f); if(!document.getElementById('fds-nom').value) document.getElementById('fds-nom').value=f.name.replace(/\.(pdf|doc|docx)$/i,'');
 }

 async function analyseIA(){
 if(!currentFileB64){toast('Charge un fichier d\'abord','e');return;}
 var apiKey=getApiKey(); if(!apiKey){toast('Clé API manquante dans l\'onglet Entreprise','e');return;}
 var btn=document.getElementById('btn-ai'); btn.disabled=true; btn.innerHTML='<span class="spinner"></span> Traitement...';
 try {
 var mediaType=currentFileType==='pdf'?'application/pdf':'application/vnd.openxmlformats-officedocument.wordprocessingml.document';
 var res=await fetch('https://api.anthropic.com/v1/messages',{
 method:'POST',
 headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
 body:JSON.stringify({
 model:'claude-3-5-sonnet-20241022', max_tokens:1000,
 messages:[{role:'user',content:[
 {type:'document',source:{type:'base64',media_type:mediaType,data:currentFileB64}},
 {type:'text',text:'Analyse cette FDS et retourne UNIQUEMENT ce JSON :\n{"h":["H317","H319"],"p":["P102","P280"],"ghs":["GHS07"],"ufi_requis":true,"allergenes":"Linalool","resume":""}'}
 ]}]
 })
 });
 var data=await res.json();
 if(data.error){ toast('Erreur API Anthropic','e'); btn.disabled=false; btn.textContent='✨ Analyser avec l\'IA'; return; }
 var textRes=data.content[0].text; aiExtracted=JSON.parse(textRes);
 document.getElementById('ai-result').className='ok-box'; document.getElementById('ai-result').style.display='block';
 document.getElementById('ai-result').textContent='Analyse terminée avec succès ! Données extraites prêtes à l\'emploi.';
 toast('Données extraites ✓','s');
 } catch(e) {
 toast('Erreur lors de l\'analyse','e');
 }
 btn.disabled=false; btn.textContent='✨ Analyser avec l\'IA';
 }

 function getApiKey(){return localStorage.getItem(API_KEY_K)||'';}
 function loadApiKey(){ var k=getApiKey(); if(k)document.getElementById('r-api-key').value=k;}
 function saveApiKey(){ localStorage.setItem(API_KEY_K, document.getElementById('r-api-key').value.trim()); toast('Clé mise à jour','s');}
 function toggleKey(){ var x=document.getElementById('r-api-key'); x.type=x.type==='password'?'text':'password'; }

 function toast(m,t){
 var el=document.getElementById('toast'); el.textContent=m; el.className='toast '+(t==='s'?'s':'e');
 clearTimeout(toastT); toastT=setTimeout(function(){el.classList.add('hi');},3000);
 }

 window.onload=init;
</script>
