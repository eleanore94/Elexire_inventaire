 function mkGHSSvg(id,size,nb){
 size=size||44; var color=nb?'#000':'#e00';
 var s=size; var half=s/2; var pad=s*0.08;
 var pts=half+','+pad+' '+(s-pad)+','+half+' '+half+','+(s-pad)+' '+pad+','+half;
 var sym=getGHSSymbolPath(id,s);
 return '<svg width="'+s+'" height="'+s+'" viewBox="0 0 '+s+' '+s+'" xmlns="http://www.w3.org/2000/svg" style="display:block; max-width:100%;">'+
 '<polygon points="'+pts+'" fill="white" stroke="'+color+'" stroke-width="'+(s*0.08)+'"/>'+ sym+ '</svg>';
 }

 function getGHSSymbolPath(id,s){
 var cx=s/2, cy=s/2, c='#000'; var sc=s/44;
 switch(id){
 case 'GHS01': return '<circle cx="'+cx+'" cy="'+(cy-2*sc)+'" r="'+(7*sc)+'" fill="'+c+'"/>';
 case 'GHS02': return '<path d="M'+cx+','+(cy+10*sc)+' C'+(cx-8*sc)+','+(cy+5*sc)+' '+(cx-10*sc)+','+(cy-2*sc)+' '+(cx-3*sc)+','+(cy-8*sc)+' Z" fill="'+c+'"/>';
 case 'GHS03': return '<circle cx="'+cx+'" cy="'+(cy+3*sc)+'" r="'+(7*sc)+'" fill="none" stroke="'+c+'" stroke-width="'+(2.5*sc)+'"/>';
 case 'GHS07': return '<rect x="'+(cx-2.5*sc)+'" y="'+(cy-10*sc)+'" width="'+(5*sc)+'" height="'+(12*sc)+'" fill="'+c+'"/>'+'<circle cx="'+cx+'" cy="'+(cy+5*sc)+'" r="'+(3*sc)+'" fill="'+c+'"/>';
 case 'GHS08': return '<path d="M'+cx+','+(cy-10*sc)+' L'+cx+','+(cy+5*sc)+'" stroke="'+c+'" stroke-width="'+(3*sc)+'"/>';
 case 'GHS09': return '<path d="M'+(cx-8*sc)+','+cy+' C'+(cx-5*sc)+','+(cy-5*sc)+' '+(cx+5*sc)+','+(cy-5*sc)+' '+(cx+8*sc)+','+cy+' Z" fill="'+c+'"/>';
 default: return '<circle cx="'+cx+'" cy="'+cy+'" r="'+(3*sc)+'" fill="'+c+'"/>';
 }
 }

