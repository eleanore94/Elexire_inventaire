 id:Date.now().toString(),nom:nom,
 recette_id:document.getElementById('c-recette').value, fds_id:document.getElementById('c-fds').value,
 qte:document.getElementById('c-qte').value, lot:document.getElementById('c-lot').value,
 ings:getIngs(), allergenes:document.getElementById('c-allergenes').value,
 avert:document.getElementById('c-avert').value, ufi:document.getElementById('c-ufi').value, ufi_req:document.getElementById('c-ufi-req').value,
 ghs:selectedGHS.slice(),h:selectedH.slice(),p:selectedP.slice(), h_custom:document.getElementById('c-h-custom').value, p_custom:document.getElementById('c-p-custom').value,
 format:document.getElementById('c-format').value, larg:document.getElementById('c-larg').value, haut:document.getElementById('c-haut').value, diam:document.getElementById('c-diam').value,
