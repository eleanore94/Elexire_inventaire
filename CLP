 function getIngs(){
 var res=[];
 document.querySelectorAll('[id^="ing-row-"]').forEach(function(row){
 var idx=row.id.replace('ing-row-','');
 var nom=document.getElementById('ing-nom-'+idx)?document.getElementById('ing-nom-'+idx).value.trim():'';
 var pct=document.getElementById('ing-pct-'+idx)?parseFloat(document.getElementById('ing-pct-'+idx).value):0;
 if(nom)res.push({nom:nom,pct:pct||0});
 });
 // TRI RÉGLEMENTAIRE PAR ORDRE DÉCROISSANT DE POIDS
 res.sort(function(a,b){return b.pct - a.pct;});
 return res;
 }

