 (pTexts.length?'<div style="font-size:'+fs(7.5)+'px;color:'+gris+'">'+pTexts.join(' ')+'</div>':'')+
 
 // BLOC NUMÉRIQUE & PAIEMENT REGLEMENTAIRE OBLIGATOIRE (QR CODE INLINE)
 '<div style="margin-top:auto;border-top:1px solid #ccc;padding-top:'+Math.round(4*scale)+'px;display:flex;justify-content:between;align-items:center;gap:6px;">'+
 '<div style="flex:1;">'+
