 function closePrint(){document.getElementById('m-print').classList.add('hi');}
 function updPrintPrev(){
 var n=Math.min(parseInt(document.getElementById('print-n').value)||1,12);
 var nb=document.getElementById('print-mode').value==='nb';
 var h='';for(var i=0;i<n;i++)h+='<div style="display:inline-block;margin:4px">'+buildLabel(0.7,nb)+'</div>';
