 var hasResp=!!(resp.nom&&resp.adresse&&resp.tel);
 items.push({ok:hasResp,txt:'Responsable complet (nom + adresse + tél)'+(hasResp?'':' → Obligatoire ! À configurer dans l\'onglet ⚙️ Entreprise')});
