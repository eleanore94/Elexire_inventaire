 if(selectedH.length>0||selectedGHS.length>0){
 items.push({ok:!!avert,txt:'Mot d\'avertissement'+(avert?' : '+avert:'')});
 }

 var allH=[...selectedH]; if(hCustom)hCustom.split(';').forEach(function(h){if(h.trim())allH.push(h.trim());});
