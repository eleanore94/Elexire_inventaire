 '<path d="M2 2h3v3H2zm0 20h3v3H2zm20-20h3v3h-3zM9 1h2v3H9zm4 0h2v1h-2zm0 4h3v2h-3zm-4 4h5v2H9zm7 0h3v2h-3zm4 2h2v4h-2zm-9 3h2v3H9zm4 2h3v2h-3zm4 3h2v4h-2zm-7 2h3v1h-3z" fill="#000"/>'+
 '</svg>';
