 }
 function imprimerApercu(){
 if(!currentApercuId)return; var c=clps.filter(function(x){return x.id===currentApercuId;})[0];
 var win=window.open('','_blank','width=600,height=500'); win.document.write('<html><body>'+c.html+'</body></html>'); win.print(); win.close();
