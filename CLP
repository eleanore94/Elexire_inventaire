 try{clps=JSON.parse(localStorage.getItem(CLP_KEY)||'[]');}catch(e){clps=[];}
 try{fdsList=JSON.parse(localStorage.getItem(FDS_KEY)||'[]');}catch(e){fdsList=[];}
 try{recs=JSON.parse(localStorage.getItem(REC_KEY)||'[]');}catch(e){recs=[];}
 try{resp=JSON.parse(localStorage.getItem(RESP_KEY)||'{}');}catch(e){resp={};}
 fillRecs();fillFdsSel();fillResp();loadApiKey();
 buildGHSGrid();buildHList();buildPList();
 addIng();
 var d=new Date();
 document.getElementById('c-lot').value='LOT-'+d.getFullYear()+String(d.getMonth()+1).padStart(2,'0')+String(d.getDate()).padStart(2,'0');
