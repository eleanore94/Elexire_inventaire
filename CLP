 function onFdsChange(){
 var fid=document.getElementById('c-fds').value; if(!fid)return;
 var f=fdsList.filter(function(x){return x.id===fid;})[0]; if(!f||!f.extracted)return;
 if(confirm('Appliquer les mentions H&P extraites de cette FDS ?')){
 resetHPSelection();
 (f.extracted.ghs||[]).forEach(function(id){if(selectedGHS.indexOf(id)<0)toggleGHS(id);});
 (f.extracted.h||[]).forEach(function(code){if(selectedH.indexOf(code)<0)toggleH(code);});
 (f.extracted.p||[]).forEach(function(code){if(selectedP.indexOf(code)<0)toggleP(code);});
 if(f.extracted.ufi_requis)document.getElementById('c-ufi-req').value='oui';
 updAll();toast('Mentions H&P appliquées depuis la FDS ✓','s');
 }
