 return'<div class="hp-item" id="pi-'+p.code+'" onclick="toggleP(\''+p.code+'\')">'+ '<input type="checkbox" id="pc-'+p.code+'" onclick="event.stopPropagation()">'+ '<div><span class="hp-code">'+p.code+'</span><span class="hp-text">'+p.text+'</span></div></div>';
 }).join('');
