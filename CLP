 (compText?'<div style="font-size:'+fs(7.5)+'px;color:'+gris+';"><strong>Composition :</strong> '+compText+'</div>':'')+
 (ghsHtml||avert?
 '<div style="display:flex;align-items:center;gap:'+Math.round(6*scale)+'px;margin: '+Math.round(2*scale)+'px 0;">'+
