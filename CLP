 return'<div class="clp-card"><div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;"><div style="flex:1;"><div style="font-size:14px;font-weight:700">'+c.nom+'</div><div style="font-size:11px;color:#a08060;margin-top:2px;">'+c.date+'</div></div><div style="display:flex;gap:5px;"><button class="btn bg bsm" onclick="ouvrirApercu(\''+c.id+'\')">👁️</button><button class="btn bg bsm" onclick="loadClp(\''+c.id+'\')">✏️</button><button class="btn bd bsm" onclick="delClp(\''+c.id+'\')">🗑</button></div></div><div style="margin-top:10px; overflow:auto;">'+c.html+'</div></div>';
 }).join('');
