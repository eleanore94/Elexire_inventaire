<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Elexire — Étiquettes CLP</title>
<style>
 *{box-sizing:border-box;margin:0;padding:0}
 body{background:#fdf8f3;font-family:Georgia,serif;color:#3a2c1e;min-height:100vh}
 ::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:#c9a97a;border-radius:4px}
 .header{background:linear-gradient(140deg,#2e1f0e,#6d5339);padding:24px 20px 16px}
 .header-row{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;flex-wrap:wrap}
 .brand{font-size:22px;font-weight:700;color:#f5ece0;letter-spacing:.02em}
 .brand-sub{font-size:12px;color:#c9a97a;margin-top:2px}
 .hbtns{display:flex;gap:7px;flex-wrap:wrap}
 .hbtn{background:rgba(255,255,255,.12);color:#c9a97a;border:1px solid rgba(201,169,122,.3);font-size:12px;padding:7px 12px;border-radius:8px;cursor:pointer;font-family:inherit;font-weight:700;text-decoration:none;display:inline-block}
 .hbtn:hover{background:rgba(255,255,255,.2)}
 .stats{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap}
 .stat{background:rgba(255,255,255,.09);border-radius:10px;padding:9px 14px;text-align:center;min-width:65px}
 .stat-n{font-size:18px;font-weight:700;color:#f5ece0}
 .stat-l{font-size:10px;color:#c9a97a}
 .tabs{display:flex;border-bottom:2px solid #e8d9c2;background:#fff;overflow-x:auto}
 .tab{cursor:pointer;padding:12px 16px;font-size:13px;font-weight:700;color:#a08060;border:none;background:transparent;font-family:inherit;border-bottom:3px solid transparent;margin-bottom:-2px;white-space:nowrap}
 .tab.on{color:#6d5339;border-bottom-color:#6d5339}
 .tab:hover:not(.on){color:#6d5339;background:#fdf8f3}
 .page{padding:16px;display:none;padding-bottom:90px}
 .page.on{display:block}
 .btn{cursor:pointer;border:none;border-radius:8px;font-family:inherit;font-weight:700;display:inline-flex;align-items:center;gap:5px;transition:all .15s}
 .bp{background:#6d5339;color:#fff;padding:9px 18px;font-size:14px}
 .bp:hover{background:#523d2a}
 .bg{background:transparent;color:#8b6f4e;padding:7px 13px;border:1.5px solid #c9a97a;font-size:13px}
 .bg:hover{background:#f5ece0}
 .bd{background:transparent;color:#b03a2e;padding:5px 10px;border:1.5px solid #e8b4b0;font-size:12px}
 .bd:hover{background:#fdf0ef}
 .bsm{padding:5px 10px;font-size:12px}
 .bgreen{background:#1e7e4a;color:#fff;padding:10px 16px;font-size:14px;border-radius:8px;border:none;font-family:inherit;font-weight:700;cursor:pointer;width:100%;transition:all .15s}
 .bgreen:hover{background:#155c35}
 .bblue{background:#1a6496;color:#fff;padding:10px 16px;font-size:14px;border-radius:8px;border:none;font-family:inherit;font-weight:700;cursor:pointer;width:100%;transition:all .15s}
 .bblue:hover{background:#124d73}
 .bai{background:linear-gradient(135deg,#6d5339,#c9a97a);color:#fff;padding:10px 16px;font-size:14px;border-radius:8px;border:none;font-family:inherit;font-weight:700;cursor:pointer;width:100%;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .15s}
 .bai:hover{opacity:.9}
 .bai:disabled{opacity:.5;cursor:not-allowed}
 .card{background:#fff;border-radius:12px;padding:15px 17px;border:1px solid #e8d9c2;margin-bottom:12px}
 .card-title{font-size:15px;font-weight:700;margin-bottom:12px;color:#3a2c1e;display:flex;align-items:center;gap:7px}
 .inp{width:100%;padding:9px 12px;border:1.5px solid #ddd0be;border-radius:8px;font-family:inherit;font-size:14px;background:#fdf8f3;color:#3a2c1e;outline:none;transition:border .15s}
 .inp:focus{border-color:#8b6f4e}
 select.inp{cursor:pointer}
 .lbl{font-size:11px;font-weight:700;color:#8b6f4e;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;display:block}
 .g2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
 .g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
 @media(max-width:500px){.g2{grid-template-columns:1fr}.g3{grid-template-columns:1fr 1fr}}
 .fgrp{display:flex;flex-direction:column;gap:13px}
 .hint{font-size:12px;color:#a08060;margin-top:4px}
 .sep{border:none;border-top:1px solid #ede0cc;margin:14px 0}
 .info-box{background:#d1ecf1;border:1px solid #bee5eb;border-radius:8px;padding:10px 14px;font-size:13px;color:#0c5460}
 .warn-box{background:#fff3cd;border:1px solid #ffc107;border-radius:8px;padding:10px 14px;font-size:13px;color:#7d5a00}
 .err-box{background:#fde8e8;border:1px solid #e8b4b0;border-radius:8px;padding:10px 14px;font-size:13px;color:#9b1c1c}
 .ok-box{background:#d4edda;border:1px solid #a8d9b8;border-radius:8px;padding:10px 14px;font-size:13px;color:#1a5c35}
 .ghs-grid{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px}
 .ghs-item{display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;padding:6px;border-radius:8px;border:2px solid transparent;transition:all .15s;background:#f5f5f5}
 .ghs-item.sel{border-color:#6d5339;background:#f5ece0}
 .ghs-item:hover:not(.sel){background:#f0ede6}
 .ghs-label{font-size:9px;color:#8b6f4e;font-weight:700;text-align:center;max-width:50px}
 .hp-grid{display:flex;flex-direction:column;gap:5px;max-height:180px;overflow-y:auto;padding:2px}
 .hp-item{display:flex;align-items:flex-start;gap:8px;padding:7px 10px;background:#f5ece0;border-radius:8px;cursor:pointer;transition:background .15s}
 .hp-item.sel{background:#d4edda;border:1px solid #a8d9b8}
 .hp-item input[type=checkbox]{margin-top:2px;flex-shrink:0;accent-color:#6d5339}
 .hp-code{font-weight:700;font-size:12px;color:#6d5339;min-width:55px;flex-shrink:0}
 .hp-text{font-size:12px;color:#3a2c1e;line-height:1.4}
 .ing-row{display:flex;gap:8px;align-items:center;margin-bottom:6px;flex-wrap:wrap}
 .ing-row .inp{flex:2;min-width:120px}
 .ing-pct{flex:1;min-width:70px}
 .preview-wrap{background:#888;border-radius:12px;padding:20px;display:flex;justify-content:center;align-items:center;min-height:180px;overflow:auto}
 .fds-card{background:#fff;border-radius:12px;border:1px solid #e8d9c2;padding:13px 15px;margin-bottom:8px}
 .upload-zone{border:2px dashed #c9a97a;border-radius:10px;padding:20px;text-align:center;cursor:pointer;transition:all .2s;background:#fdf8f3}
 .upload-zone:hover,.upload-zone.drag{background:#f5ece0;border-color:#6d5339}
 .ai-result{background:#f0f7f4;border:1px solid #a8d9b8;border-radius:10px;padding:14px;margin-top:10px}
 .spinner{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite}
 @keyframes spin{to{transform:rotate(360deg)}}
 .clp-card{background:#fff;border-radius:12px;border:1px solid #e8d9c2;padding:13px 15px;margin-bottom:8px}
 .tag{display:inline-flex;align-items:center;padding:3px 9px;border-radius:10px;font-size:11px;font-weight:700;margin:2px}
 .tb{background:#d1ecf1;color:#0c5460}
 .tg{background:#d4edda;color:#1a5c35}
 .to{background:#fff3cd;color:#7d5a00}
 .tr{background:#fde8e8;color:#9b1c1c}
 .tp{background:#f3e6fa;color:#6a1b9a}
 .val-item{display:flex;align-items:flex-start;gap:8px;padding:6px 0;font-size:13px;border-bottom:1px solid #f0e8de}
 .val-item:last-child{border-bottom:none}
 .val-ok{color:#1a5c35;font-size:15px;flex-shrink:0}
 .val-err{color:#b03a2e;font-size:15px;flex-shrink:0}
 .val-warn{color:#7d5a00;font-size:15px;flex-shrink:0}
 .overlay{position:fixed;inset:0;background:rgba(30,20,10,.5);z-index:100;display:flex;align-items:center;justify-content:center;padding:14px}
 .overlay.hi{display:none}
 .modal{background:#fdf8f3;border-radius:16px;padding:24px;max-width:560px;width:100%;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(30,20,10,.3)}
 .mtitle{font-size:18px;font-weight:700;margin-bottom:16px;color:#3a2c1e}
 .mfoot{display:flex;gap:10px;justify-content:flex-end;margin-top:14px}
 .empty{text-align:center;padding:40px 20px;color:#b8a090}
 .empty-i{font-size:34px;margin-bottom:8px}
 .empty-t{font-size:15px;font-weight:700;margin-bottom:4px}
 .toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);padding:10px 22px;border-radius:28px;font-weight:700;font-size:13px;z-index:200;pointer-events:none;opacity:1;transition:opacity .3s}
 .toast.s{background:#2d6a4f;color:#fff}
 .toast.e{background:#b03a2e;color:#fff}
 .toast.hi{opacity:0}
</style>
</head>
<body>
 <div class="header">
 <div class="header-row">
 <div><div class="brand">✦ Elexire</div><div class="brand-sub">Étiquettes CLP — Conforme CE 1272/2008 & Normes 2026</div></div>
 <div class="hbtns">
 <a href="index.html" class="hbtn">📦</a>
 <a href="atelier.html" class="hbtn">🧪</a>
 <a href="prix.html" class="hbtn">💰</a>
 <a href="ventes.html" class="hbtn">🛍️</a>
 <a href="reglages.html" class="hbtn">⚙️</a>
 </div>
 </div>
 <div class="stats">
 <div class="stat"><div class="stat-n" id="sn-clp">0</div><div class="stat-l">Étiquettes</div></div>
 <div class="stat"><div class="stat-n" id="sn-fds">0</div><div class="stat-l">FDS</div></div>
 <div class="stat"><div class="stat-n" id="sn-rec">0</div><div class="stat-l">Recettes</div></div>
 </div>
 </div>
 <div class="tabs">
 <button class="tab on" onclick="goTab('creer',this)">🏷️ Créer CLP</button>
 <button class="tab" onclick="goTab('fds',this)">📄 FDS</button>
 <button class="tab" onclick="goTab('biblio',this)">📚 Bibliothèque</button>
 <button class="tab" onclick="goTab('regl',this)">⚙️ Entreprise</button>
 </div>
 
 <!-- ══ CRÉER CLP ══ -->
 <div class="page on" id="page-creer">
 <div class="card">
 <div class="card-title">🕯️ 1. Identification du produit</div>
 <div class="fgrp">
 <div>
 <label class="lbl">Lier à une recette (optionnel)</label>
 <select class="inp" id="c-recette" onchange="onRecChange()">
 <option value="">— Saisie manuelle —</option>
 </select>
 </div>
 <div class="g2">
 <div><label class="lbl">Nom du produit *</label><input class="inp" id="c-nom" placeholder="ex: Fondant Brioche au beurre" oninput="updAll()"></div>
 <div><label class="lbl">Quantité nette *</label><input class="inp" id="c-qte" placeholder="ex: 10 g" oninput="updAll()"></div>
 </div>
 <div class="g2">
 <div><label class="lbl">N° de lot</label><input class="inp" id="c-lot" oninput="updAll()"></div>
 <div>
 <label class="lbl">FDS liée</label>
 <select class="inp" id="c-fds" onchange="onFdsChange()">
 <option value="">— Aucune —</option>
 </select>
 </div>
 </div>
 </div>
 </div>
 <div class="card">
 <div class="card-title">🧴 2. Composition & ingrédients</div>
 <div class="fgrp">
 <div class="info-box" style="font-size:12px">Liste tous les composants avec leur pourcentage. Ils seront triés automatiquement par ordre décroissant sur l'étiquette (obligation légale).</div>
 <div id="ing-list"></div>
 <button class="btn bg bsm" onclick="addIng()">+ Ajouter un ingrédient</button>
 <div>
 <label class="lbl">Allergènes — Phrase EUH208 (obligatoire si applicable)</label>
 <input class="inp" id="c-allergenes" placeholder="ex: Coumarine, Benzyl benzoate, Linalool" oninput="updAll()">
 <div class="hint">Noms INCI des substances sensibilisantes présentes (section 2.2 de la FDS). Génère automatiquement la formule réglementaire complète.</div>
 </div>
 </div>
 </div>
 <div class="card">
 <div class="card-title">⚠️ 3. Classification — Pictogrammes GHS</div>
 <div class="info-box" style="margin-bottom:10px;font-size:12px"> Pictogrammes conformes CLP : losange rouge, symbole noir sur fond blanc. Sélectionne selon la FDS de ton parfum. </div>
 <div class="ghs-grid" id="ghs-grid"></div>
 <div style="margin-top:10px">
 <label class="lbl">Mot d'avertissement *</label>
 <select class="inp" id="c-avert" onchange="updAll()">
 <option value="ATTENTION">⚠️ ATTENTION (catégories moins graves — H315, H317, H319, H412...)</option>
 <option value="DANGER">🔴 DANGER (catégories graves — H302, H304, H314, H400, H410...)</option>
 <option value="">Aucun (produit non classé dangereux)</option>
 </select>
 <div class="hint">Déterminé par la catégorie de danger la plus grave. Voir section 2 de la FDS.</div>
 </div>
 </div>
 <div class="card">
 <div class="card-title">📋 4. Mentions de danger (H)</div>
 <div class="fgrp">
 <div class="warn-box" style="font-size:12px">⚠️ H411 et H412 sont mutuellement exclusifs — utilise uniquement celui qui correspond à la FDS de ton parfum.</div>
 <div class="hp-grid" id="h-list"></div>
 <div>
 <label class="lbl">Mentions H personnalisées (optionnel)</label>
 <input class="inp" id="c-h-custom" placeholder="ex: H226 Liquide et vapeurs inflammables." oninput="updAll()">
 <div class="hint">Séparées par un point-virgule si plusieurs</div>
 </div>
 </div>
 </div>
 <div class="card">
 <div class="card-title">🛡️ 5. Conseils de prudence (P)</div>
 <div class="fgrp">
 <div class="hp-grid" id="p-list"></div>
 <div>
 <label class="lbl">Conseils P personnalisés (optionnel)</label> <input class="inp" id="c-p-custom" placeholder="ex: P210 Tenir à l'écart de la chaleur." oninput="updAll()">
 <div class="hint">Séparés par un point-virgule si plusieurs</div>
 </div>
 </div>
 </div>
 <div class="card">
 <div class="card-title">🔢 6. UFI — Identifiant unique de formulation</div>
 <div class="fgrp">
 <div class="info-box" style="font-size:12px">Obligatoire si le mélange est classé dangereux pour la santé (H302, H314, H315, H317, H319...). À obtenir sur le portail PCN de l'ECHA (echa.europa.eu).</div>
 <div class="g2">
 <div>
 <label class="lbl">Code UFI</label>
 <input class="inp" id="c-ufi" placeholder="UFI: XXXX-XXXX-XXXX-XXXX" oninput="updAll()">
 </div>
 <div>
 <label class="lbl">Statut UFI</label>
 <select class="inp" id="c-ufi-req" onchange="updAll()">
 <option value="oui">✅ Obtenu — à afficher</option>
 <option value="encours">⏳ En cours d'obtention</option>
 <option value="non">❌ Non requis pour ce produit</option>
 </select>
 </div>
 </div>
 </div>
 </div>
 <div class="card">
 <div class="card-title">📐 7. Format de l'étiquette</div>
 <div class="fgrp">
 <div class="g2">
 <div>
 <label class="lbl">Format</label>
 <select class="inp" id="c-format" onchange="updFmt();updAll()">
 <option value="rect">Rectangle</option>
 <option value="carre">Carré</option>
 <option value="rond">Rond</option>
 </select>
 </div>
 <div>
 <label class="lbl">Impression</label>
 <select class="inp" id="c-imp" onchange="updAll()">
 <option value="couleur">🎨 Couleur (jet d'encre)</option>
 <option value="nb">⬛ Noir & blanc (thermique)</option>
 </select>
 </div>
 </div>
 <div class="g2" id="fmt-dims">
 <div><label class="lbl">Largeur (mm) *</label><input class="inp" type="number" id="c-larg" value="80" min="52" oninput="updAll()"></div>
 <div><label class="lbl">Hauteur (mm) *</label><input class="inp" type="number" id="c-haut" value="52" min="52" oninput="updAll()"></div>
 </div>
 <div id="fmt-diam" style="display:none">
 <label class="lbl">Diamètre (mm) *</label>
 <input class="inp" type="number" id="c-diam" value="70" min="60" oninput="updAll()">
 </div>
 <div class="info-box" style="font-size:12px" id="dim-info">
 📏 Dimensions minimales CLP pour emballages ≤ 3L : 52×74mm (ou 52x52mm si carré/rond). Pictogrammes min 10×10mm. Police Sans-Serif noire obligatoire.
 </div>
 </div>
 </div>
 <div class="card" id="validation-card">
 <div class="card-title">✅ Validation réglementaire</div>
 <div id="validation-list"></div>
 </div>
 <div class="card">
 <div class="card-title">👁️ Aperçu de l'étiquette physique + numérique (Norme 2026)</div>
 <div class="preview-wrap" id="preview-wrap">
 <div id="label-preview"></div>
 </div>
 <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap">
 <button class="bgreen" onclick="saveClp()" style="flex:1">💾 Sauvegarder</button>
 <button class="bblue" onclick="ouvrirImpression()" style="flex:1">🖨️ Imprimer / Télécharger</button>
 </div>
 </div>
 </div>

 <!-- ══ FDS ══ -->
 <div class="page" id="page-fds">
 <div style="font-size:17px;font-weight:700;margin-bottom:14px">📄 Fiches de données de sécurité</div>
 <div class="card">
 <div class="card-title">➕ Ajouter une FDS</div>
 <div class="fgrp">
 <div class="g2">
 <div><label class="lbl">Nom *</label><input class="inp" id="fds-nom" placeholder="ex: Parfum Brioche — Le Petit Grassois"></div>
 <div><label class="lbl">Catégorie</label>
 <select class="inp" id="fds-cat">
 <option value="parfum">🌸 Parfum</option>
 <option value="cire">🕯️ Cire</option>
 <option value="additif">⚗️ Additif</option>
 <option value="colorant">🎨 Colorant/Mica</option>
 <option value="autre">📦 Autre</option>
 </select>
 </div>
 </div>
 <div><label class="lbl">Fournisseur</label><input class="inp" id="fds-four" placeholder="ex: Le Petit Grassois"></div>
 <div>
 <label class="lbl">Fichier FDS (PDF ou Word)</label>
 <div class="upload-zone" id="upload-zone" onclick="document.getElementById('fds-file').click()" ondragover="event.preventDefault();this.classList.add('drag')" ondragleave="this.classList.remove('drag')" ondrop="onDrop(event)">
 <div style="font-size:28px;margin-bottom:6px">📄</div>
 <div style="font-weight:700;font-size:14px;color:#6d5339">Glisse ton fichier ici</div>
 <div style="font-size:12px;color:#a08060;margin-top:4px">ou clique · PDF ou Word</div>
 <div id="fds-file-name" style="font-size:12px;color:#6d5339;font-weight:700;margin-top:8px;display:none"></div>
 </div>
 <input type="file" id="fds-file" accept=".pdf,.doc,.docx" style="display:none" onchange="onFileSelect(event)">
 </div>
 <div><label class="lbl">Notes</label><input class="inp" id="fds-notes" placeholder="Réf commande, N° lot..."></div>
 <button class="bai" id="btn-ai" onclick="analyseIA()" disabled> ✨ Analyser avec l'IA — extraction H&P automatique </button>
 <div class="hint" style="text-align:center">Extrait automatiquement les pictogrammes GHS, mentions H&P, UFI requis. Utilise quelques centimes de crédit API.</div>
 <div id="ai-result" style="display:none"></div>
 <button class="bgreen" onclick="saveFds()">💾 Sauvegarder la FDS</button>
 </div>
 </div>
 <div style="font-size:15px;font-weight:700;margin-bottom:10px">Mes FDS</div>
 <div id="list-fds"></div>
 </div>

 <!-- ══ BIBLIOTHÈQUE ══ -->
 <div class="page" id="page-biblio">
 <div style="font-size:17px;font-weight:700;margin-bottom:14px">📚 Mes étiquettes CLP</div>
 <div id="list-clp"></div>
 </div>

 <!-- ══ ENTREPRISE ══ -->
 <div class="page" id="page-regl">
 <div class="card">
 <div class="card-title">🏢 Informations responsable (obligatoires sur l'étiquette)</div>
 <div class="fgrp">
 <div><label class="lbl">Nom / Raison sociale *</label><input class="inp" id="r-nom" placeholder="ex: Elexire — Eléonore Grassin" oninput="updAll()"></div>
 <div><label class="lbl">Adresse complète *</label><input class="inp" id="r-adresse" placeholder="ex: 8 rue Arsène Bourgeois, 45000 Orléans, France" oninput="updAll()"></div>
 <div class="g2">
 <div><label class="lbl">Téléphone *</label><input class="inp" id="r-tel" placeholder="+33 6 XX XX XX XX" oninput="updAll()"></div>
 <div><label class="lbl">Email</label><input class="inp" id="r-email" placeholder="contact@elexire.fr" oninput="updAll()"></div>
 </div>
 <button class="bgreen" onclick="saveResp()">💾 Sauvegarder</button>
 </div>
 </div>
 <div class="card">
 <div class="card-title">🔑 Clé API Anthropic (pour info FDS)</div>
 <div class="fgrp">
 <div class="warn-box" style="font-size:12px">⚠️ Stockée uniquement en local (localStorage).</div>
 <div>
 <label class="lbl">Clé API (sk-ant-...)</label>
 <div style="display:flex;gap:8px">
 <input class="inp" type="password" id="r-api-key" placeholder="sk-ant-api03-..." style="flex:1;font-family:monospace">
 <button class="btn bg bsm" onclick="toggleKey()">👁️</button>
 </div>
 </div>
 <button class="bgreen" onclick="saveApiKey()">💾 Sauvegarder la clé</button>
 </div>
 </div>
 </div>

 <!-- MODALS -->
 <div class="overlay hi" id="m-print" onclick="if(event.target===this)closePrint()">
 <div class="modal">
