 function ouvrirApercu(id){
 var c=clps.filter(function(x){return x.id===id;})[0];if(!c)return; currentApercuId=id;
 document.getElementById('m-apercu-title').textContent='👁️ '+c.nom; document.getElementById('m-apercu-content').innerHTML=c.html;
